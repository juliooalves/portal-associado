@model MeusDadosViewModel
@{
    ViewData["Title"] = "Meus Dados";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <h1 class="h3 mb-4">Meus Dados</h1>

        @if (TempData["Sucesso"] is string sucesso)
        {
            <div class="alert alert-success" role="alert">@sucesso</div>
        }

        <div class="card shadow-sm mb-4">
            <div class="card-header">Dados cadastrais</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Nome</dt>
                    <dd class="col-sm-9">@Model.Dados.Nome</dd>

                    <dt class="col-sm-3">CPF</dt>
                    <dd class="col-sm-9">@Model.Dados.Cpf</dd>

                    <dt class="col-sm-3">Placa</dt>
                    <dd class="col-sm-9">@Model.Dados.Placa</dd>

                    <dt class="col-sm-3">Telefone</dt>
                    <dd class="col-sm-9 mb-0">@Model.Dados.Telefone</dd>
                </dl>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header">Endereço</div>
            <div class="card-body">
                <form asp-controller="MeusDados" asp-action="AtualizarEndereco" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Endereco.Logradouro" class="form-label"></label>
                            <input asp-for="Endereco.Logradouro" class="form-control" />
                            <span asp-validation-for="Endereco.Logradouro" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Endereco.Numero" class="form-label"></label>
                            <input asp-for="Endereco.Numero" class="form-control" />
                            <span asp-validation-for="Endereco.Numero" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Endereco.Complemento" class="form-label"></label>
                            <input asp-for="Endereco.Complemento" class="form-control" />
                            <span asp-validation-for="Endereco.Complemento" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Endereco.Bairro" class="form-label"></label>
                            <input asp-for="Endereco.Bairro" class="form-control" />
                            <span asp-validation-for="Endereco.Bairro" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Endereco.Cidade" class="form-label"></label>
                            <input asp-for="Endereco.Cidade" class="form-control" />
                            <span asp-validation-for="Endereco.Cidade" class="text-danger"></span>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label asp-for="Endereco.Uf" class="form-label"></label>
                            <input asp-for="Endereco.Uf" class="form-control" maxlength="2" />
                            <span asp-validation-for="Endereco.Uf" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Endereco.Cep" class="form-label"></label>
                            <input asp-for="Endereco.Cep" class="form-control" placeholder="00000-000" />
                            <span asp-validation-for="Endereco.Cep" class="text-danger"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">Salvar endereço</button>
                </form>
            </div>
        </div>
    </div>
</div>
